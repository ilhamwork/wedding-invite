# Supabase project credentials — Project Settings → API in your Supabase dashboard
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Demo-only password gate for /admin/checkin.
